{
  "manifest_version": 3,
  "name": "Synapse PR Conflict Watcher",
  "short_name": "Synapse",
  "version": "0.2.2",
  "description": "Adds a Synapse status badge to GitHub PRs showing pending agent collisions in the merge queue.",
  "author": "Aadit Rajgor",
  "homepage_url": "https://github.com/arajgor1/synapse",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://github.com/*"],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/pull/*", "https://github.com/*/pulls"],
      "js": ["src/content.js"],
      "css": ["src/badge.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Synapse — multi-agent PR conflict status",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
