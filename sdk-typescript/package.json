{
  "name": "synapse-protocol",
  "version": "0.2.9",
  "description": "Synapse — audit, observability, conflict detection, intent capture, and reasoning capture for agentic teams that span vendor SDKs. TypeScript SDK.",
  "keywords": [
    "agents",
    "agentic",
    "multi-agent",
    "audit",
    "observability",
    "coordination",
    "protocol",
    "compliance",
    "envelope",
    "ai"
  ],
  "homepage": "https://github.com/arajgor1/synapse",
  "bugs": "https://github.com/arajgor1/synapse/issues",
  "license": "Apache-2.0",
  "author": "Aadit Rajgor",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters/mock": {
      "types": "./dist/adapters/mock.d.ts",
      "import": "./dist/adapters/mock.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ioredis": "^5.4.1",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arajgor1/synapse.git",
    "directory": "sdk-typescript"
